{
  "description": "TCP RST for www.example.com",
  "rules": [
    {
      "type": "tcp",
      "rule": {
        "action": "reset",
        "server_addr": "104.18.26.120",
        "server_port": 80,
        "contains": "www.example.com"
      }
    },
    {
      "type": "tcp",
      "rule": {
        "action": "reset",
        "server_addr": "104.18.26.120",
        "server_port": 443,
        "contains": "www.example.com"
      }
    }
  ]
}
